{
  "identifier": "default",
  "description": "Default capability for 玩皮AI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/wanpi-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/wanpi-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write"
  ]
}
