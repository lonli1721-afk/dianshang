# =============================================================================
# game-video-tool nginx server block — 性能与安全加固模板
#
# 用途：作为生产 nginx 配置的参考蓝本。仓库里 .example 后缀的版本不会直接生效，
# 应用步骤见本文件末尾。
#
# 解决的问题（针对 1.0.7 线上巡检发现的）：
#   1. bundle 414KB 裸传无压缩 → gzip 后 ~115KB（节省 72%）
#   2. /assets/index-*.js 没有 long-cache → 浏览器二次访问每次发 304
#   3. Server: nginx/1.26.3 暴露版本号 → server_tokens off
#   4. 缺 X-Content-Type-Options / X-Frame-Options / Referrer-Policy
#
# 假定的部署路径（与 deploy/game-video-tool.service 一致）：
#   - 前端 dist:  /home/deploy/game-video-tool/react-ui/dist
#   - 后端监听:   127.0.0.1:57991
#
# 关于 add_header 的陷阱：
#   nginx 的 add_header 只要在内层 location 里出现一次，外层 server / http 块
#   设置的所有 add_header 全部失效。所以本文件在每个需要加 header 的 location
#   里都显式重申一遍——看起来重复，但是必要的。
# =============================================================================

# server_tokens 也可以放到 /etc/nginx/nginx.conf 的 http {} 块，作用更全局。
# 这里写在 server {} 内只对本 server 生效，对其他 vhost 不影响。
server_tokens off;

# ───── gzip 压缩 ─────
# nginx 默认对 text/html 已开启压缩，下面补齐 JS/CSS/JSON/SVG/字体。
gzip on;
gzip_vary on;
gzip_comp_level 5;
gzip_min_length 1024;
gzip_proxied any;
gzip_types
    text/plain
    text/css
    text/javascript
    text/xml
    application/javascript
    application/json
    application/xml
    application/xml+rss
    image/svg+xml
    font/woff
    font/woff2;

server {
    listen 80;
    # 现网如果绑定特定 IP / 域名，改成对应值（当前是裸 IP，可保留 _ 通配）
    server_name _;

    root /home/deploy/game-video-tool/react-ui/dist;
    index index.html;

    # 视频/图片上传体积上限。后端 settings 里的视频也走这个 server。
    # 当前线上 Seedance 单视频上限 15.2s，不会超过 1G，1024m 留余量。
    client_max_body_size 1024m;

    # 视频生成 / 任务轮询是长连接，超时时间放宽
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;

    # ───── 静态资源带 hash → 长缓存 immutable ─────
    # Vite 构建产物文件名自带 content hash，内容变了 hash 也变，
    # 所以可以 1 年 immutable，浏览器二次访问 0 请求。
    location ~* ^/assets/.+\.(js|css|woff2?|eot|ttf|otf|svg|gif|jpg|jpeg|png|webp|ico)$ {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        access_log off;
        try_files $uri =404;
    }

    # ───── 后端 API & 健康检查 ─────
    # /health, /api/*, /public-files/* 都由 FastAPI 处理
    location ~ ^/(health|api/|public-files/) {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;

        proxy_pass http://127.0.0.1:57991;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # 流式响应（任务轮询、文件下载）保持 chunked，不要 buffer
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # ───── 前端 SPA ─────
    # index.html 应明确告诉浏览器不要缓存，否则用户长期看不到新版
    # （CLAUDE.md §2 提到过线上曾出现旧 bundle 缓存事故）
    location = /index.html {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        try_files $uri =404;
    }

    location / {
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        try_files $uri $uri/ /index.html;
    }
}

# =============================================================================
# 应用步骤（不要直接覆盖现网，先对比合并）
# =============================================================================
#
# 1. 上传到服务器（不覆盖现有 conf）：
#      scp nginx/game-video-tool.conf.example \
#        deploy@106.53.49.23:/tmp/game-video-tool-new.conf
#
# 2. 在服务器上对比现有配置，找出差异：
#      ssh deploy@106.53.49.23
#      sudo diff /etc/nginx/conf.d/game-video-tool.conf /tmp/game-video-tool-new.conf
#      # 或 conf 在 sites-enabled 下，按你环境调整
#
# 3. 备份现有 nginx 配置：
#      sudo cp /etc/nginx/conf.d/game-video-tool.conf \
#        /etc/nginx/conf.d/game-video-tool.conf.bak-$(date +%Y%m%d-%H%M)
#
# 4. 选一种方式应用：
#    A. 全量替换（如果现有 conf 没有本模板覆盖不到的额外业务规则）：
#         sudo cp /tmp/game-video-tool-new.conf /etc/nginx/conf.d/game-video-tool.conf
#
#    B. 逐项合并（如果现有 conf 有本模板没考虑到的逻辑）：
#         手动把 server_tokens off / gzip / 安全 headers / long-cache location
#         几段 patch 进去，保留你已有的业务 location。
#
# 5. 语法校验（必做，否则下一步 reload 会让 nginx 起不来）：
#      sudo nginx -t
#
# 6. reload（非 restart，零停机）：
#      sudo systemctl reload nginx
#
# 7. 立刻验收（在服务器上或本地）：
#      curl -sSI http://106.53.49.23/ | grep -i server   # 应不再带 nginx/1.26.3
#      curl -sS --compressed -o /dev/null -w \
#        "%{size_download}\n" http://106.53.49.23/assets/index-*.js
#      # 应在 ~115000 左右（之前 423828）
#      curl -sSI http://106.53.49.23/assets/index-*.js | grep -i cache
#      # 应有 cache-control: public, max-age=31536000, immutable
#      curl -sSI http://106.53.49.23/ | grep -iE "(x-content-type|x-frame|referrer)"
#      # 三个 header 都应出现
#
# 8. 回滚（如果验收失败）：
#      sudo cp /etc/nginx/conf.d/game-video-tool.conf.bak-* \
#        /etc/nginx/conf.d/game-video-tool.conf
#      sudo nginx -t && sudo systemctl reload nginx
#
# =============================================================================
